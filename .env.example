# 本地开发环境变量（复制为 .env.local 后填写）
# cp .env.example .env.local

# 可选：开发环境标识（设为 DEV 会启用 react-dev-inspector）
COZE_PROJECT_ENV=DEV

# PostgreSQL 直连（扣子编程平台数据库，用于历史记录保存/查询）
PGDATABASE_URL=postgresql://postgres:password@host:5432/postgres?sslmode=require

# 登录会话签名密钥（生产环境请换成随机长字符串）
AUTH_SECRET=replace-with-a-long-random-secret
# 本地 HTTP 开发保持 false；HTTPS 生产环境设为 true
AUTH_COOKIE_SECURE=false

# LLM API（仅后端使用，阿里百炼 DashScope Responses API）
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_RESPONSES_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/responses
DASHSCOPE_LLM_MODEL=qwen3.7-plus

# Supabase REST API（扣子编程平台项目环境变量中获取）
# COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key

# 可选：自定义端口（macOS 上 5000 常被 AirPlay 占用，可改为 3000）
# PORT=3000
